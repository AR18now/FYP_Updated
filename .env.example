# Copy this file to `.env` in the project root and fill in your token.
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Optional: Qwen 3.5 lane (OpenAI-compatible Chat Completions — DashScope compatible-mode by default).
# Used when the UI sends srs_llm_choice=qwen35 (or when the API body includes "srs_llm_choice": "qwen35").
# QWEN35_OPENAI_API_KEY=sk-...
# QWEN35_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN35_OPENAI_MODEL=qwen-plus
# (Alias) DASHSCOPE_API_KEY=sk-...

# This project’s default Replicate model rejects max_new_tokens above 4096; code clamps automatically.
# REPLICATE_MAX_NEW_TOKENS_CAP=4096

# Optional: SRS viewer extra doc-quality POST to /api/evaluate-srs-kb-metrics (off by default; not RAG retrieval).
# REACT_APP_ENABLE_SRS_DOC_QUALITY=true

# PNG fallback when PlantUML CLI is not installed (e.g. Windows): POST to Kroki for rendering.
# DISABLE_KROKI_FALLBACK=1
# PLANTUML_HTTP_RENDER_URL=https://kroki.io/plantuml/png

# SRS generation strategy for web API:
# - model: default — direct LLM only (no retrieval)
# - rag: retrieval-augmented generation using ``final_extracted_srs_ieee830`` (or RAG_KB_PATH)
SRS_GENERATION_MODE=model

# How aggressively SRS alignment monitoring escalates to "review" (has_hallucinations in API):
# relaxed (default): long SRS vs short input is usually FYI only; review mainly for weak FR/input ties.
# balanced: middle thresholds. strict: closest to the old behavior.
# SRS_GROUNDING_STRICTNESS=relaxed

# Optional RAG controls (used when SRS_GENERATION_MODE=rag)
# If unset, the API loads: final_extracted_srs_ieee830/final_extracted_srs_ieee830/ (or parent folder).
# RAG_KB_PATH=data/knowledge_base
RAG_TOP_K=6
RAG_VECTOR_BACKEND=faiss
