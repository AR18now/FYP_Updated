@startuml
' UML 2.x Use Case Diagram (PlantUML)
top to bottom direction

title UML 2.x Use Case Diagram\n<size:12><i>e commerce</i></size>

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam defaultFontName "Segoe UI", Helvetica, Arial, sans-serif
skinparam defaultFontSize 12
skinparam TitleFontSize 14
skinparam TitleFontStyle bold
skinparam rectangle {
  BackgroundColor #F8FAFC
  BorderColor #1e3a8a
  FontColor #0f172a
  RoundCorner 10
}
skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #1d4ed8
  FontColor #0f172a
}
skinparam actor {
  BackgroundColor #EEF2FF
  BorderColor #1d4ed8
  FontColor #0f172a
}
skinparam arrow {
  Color #475569
  Thickness 1.5
}

' --- Actors (outside subject boundary) ---
actor "User" as act_0
actor "Customer" as act_1
actor "Administrator" as act_2
actor "External Payment Service (supporting)" as act_3

' --- Subject (system boundary) & use cases ---
rectangle "e commerce" {
  usecase "Display List of Available Products With Images, Descriptions, Prices, a…" as uc_0
  usecase "Filter and Display Relevant Products Based on Inputs" as uc_1
  usecase "Update Shopping Cart Database With New Entry" as uc_2
  usecase "Calculate Total Cost, Apply Discount/coupon If Applicable, Generate Ord…" as uc_3
  usecase "Input: Credit Card Number, Expiration Date, Cvv, Billing Address Proces…" as uc_4
  usecase "Validate Inputs, Update Database Accordingly" as uc_5
  usecase "Adjust Inventory Records" as uc_6
  usecase "Retrieve and Display Order Details" as uc_7
  usecase "Display List of Available Products With Images, Descriptions, Prices, a…" as uc_8
  usecase "Filter and Display Relevant Products Based on Inputs (2)" as uc_9
  usecase "Update Shopping Cart Database With New Entry (2)" as uc_10
  usecase "Calculate Total Cost, Apply Discount/coupon If Applicable, Generate Ord…" as uc_11
  usecase "Input: Credit Card Number, Expiration Date, Cvv, Billing Address Proces…" as uc_12
  usecase "Validate Inputs, Update Database Accordingly (2)" as uc_13
  usecase "Adjust Inventory Records (2)" as uc_14
  usecase "Retrieve and Display Order Details (2)" as uc_15
}

' --- Associations (actor to use case) ---
act_0 -- uc_0
act_0 -- uc_1
act_0 -- uc_2
act_1 -- uc_3
act_1 -- uc_4
act_0 -- uc_5
act_2 -- uc_6
act_1 -- uc_7
act_0 -- uc_8
act_0 -- uc_9
act_0 -- uc_10
act_1 -- uc_11
act_1 -- uc_12
act_0 -- uc_13
act_2 -- uc_14
act_1 -- uc_15

' --- Supporting actors (secondary associations) ---
act_3 -- uc_3
act_3 -- uc_11
act_3 -- uc_4
act_3 -- uc_12
act_3 -- uc_7
act_3 -- uc_15

' --- <<include>> ---
uc_8 ..> uc_0 : include
uc_9 ..> uc_1 : include
uc_10 ..> uc_2 : include
uc_11 ..> uc_3 : include
uc_13 ..> uc_5 : include
uc_14 ..> uc_6 : include
uc_15 ..> uc_7 : include

note bottom
  UML 2 use case view: subject boundary, actors, use cases, associations.
  Include and extend dependencies use standard UML stereotypes on the links.
end note

@enduml
