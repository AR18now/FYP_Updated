@startuml
' UML 2.x Use Case Diagram (PlantUML)
top to bottom direction

title UML 2.x Use Case Diagram\n<size:12><i>hospital</i></size>

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam defaultFontName "Segoe UI", Helvetica, Arial, sans-serif
skinparam defaultFontSize 12
skinparam TitleFontSize 14
skinparam TitleFontStyle bold
skinparam rectangle {
  BackgroundColor #F8FAFC
  BorderColor #1e3a8a
  FontColor #0f172a
  RoundCorner 10
}
skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #1d4ed8
  FontColor #0f172a
}
skinparam actor {
  BackgroundColor #EEF2FF
  BorderColor #1d4ed8
  FontColor #0f172a
}
skinparam arrow {
  Color #475569
  Thickness 1.5
}

' --- Actors (outside subject) ---
actor "User" as act_0

' --- Subject (system boundary) & use cases ---
rectangle "hospital" {
  usecase "Find Doctor By Specialty" as uc_0
  usecase "Book Appointment" as uc_1
  usecase "Get Reminders" as uc_2
  usecase "Block Unavailable Slots" as uc_3
  usecase "View Daily Schedule" as uc_4
  usecase "Mark Completed Visits" as uc_5
  usecase "Handle Walk-In Patients" as uc_6
  usecase "Reschedule Appointments" as uc_7
  usecase "Cancel Appointments" as uc_8
  ' vertical stack hint
  uc_0 -[hidden]down- uc_1
  uc_1 -[hidden]down- uc_2
  uc_2 -[hidden]down- uc_3
  uc_3 -[hidden]down- uc_4
  uc_4 -[hidden]down- uc_5
  uc_5 -[hidden]down- uc_6
  uc_6 -[hidden]down- uc_7
  uc_7 -[hidden]down- uc_8
}

' --- Associations (actor to use case) ---
act_0 -- uc_0
act_0 -- uc_1
act_0 -- uc_2
act_0 -- uc_3
act_0 -- uc_4
act_0 -- uc_5
act_0 -- uc_6
act_0 -- uc_7
act_0 -- uc_8

note bottom
  **UML 2.x use case diagram**: subject (boundary), actors, use cases, associations.
end note

@enduml
